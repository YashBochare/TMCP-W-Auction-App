{
  "name": "tmcp-w-auction-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @auction/api\" \"npm run dev -w @auction/web\"",
    "build": "npm run build -w @auction/shared && npm run build -w @auction/api && npm run build -w @auction/web",
    "lint": "npm run lint -w @auction/web && tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
